{
  "name": "codeviz",
  "version": "0.1.0",
  "description": "Decorator-based code visualization — static, deterministic extraction of an architecture graph from annotated Python code.",
  "type": "module",
  "bin": {
    "codeviz": "bin/codeviz.js"
  },
  "files": [
    "dist/",
    "python/",
    "bin/"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "npm run build:server && npm run build:ui",
    "build:server": "tsc -p tsconfig.build.json",
    "build:ui": "vite build",
    "dev:ui": "vite",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:ui": "tsc -p ui/tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "license": "MIT",
  "dependencies": {
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2",
    "ignore": "^6.0.2",
    "yaml": "^2.5.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cytoscape": "^3.21.8",
    "@types/node": "^22.7.4",
    "cytoscape": "^3.30.2",
    "cytoscape-dagre": "^2.5.0",
    "eslint": "^9.12.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.8.0",
    "vite": "^5.4.8",
    "vitest": "^2.1.2"
  }
}
